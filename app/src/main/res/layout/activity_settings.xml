<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/zt_navy_darkest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/topbar_bg"
        android:paddingTop="44dp"
        android:paddingBottom="16dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#C8DFF5"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ALARM" android:textColor="#1A4060" android:textSize="9sp"
                android:textStyle="bold" android:letterSpacing="0.15" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:text="🔔" android:textSize="13sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ringtone" android:textColor="#A8D4F0" android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Alert sound" android:textColor="#3A6080" android:textSize="10sp"/>
                    </LinearLayout>
                    <Spinner android:id="@+id/spinnerRingtone" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:backgroundTint="#2DA86E"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#0A2A40"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:text="📳" android:textSize="13sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Vibration" android:textColor="#A8D4F0" android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Haptic feedback on alert" android:textColor="#3A6080" android:textSize="10sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switchVibration" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:checked="true"
                        android:thumbTint="#2DA86E" android:trackTint="#0A3050"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#0A2A40"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:text="🔊" android:textSize="13sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Alarm Sound" android:textColor="#A8D4F0" android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Play ringtone on alert" android:textColor="#3A6080" android:textSize="10sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switchRing" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:checked="true"
                        android:thumbTint="#2DA86E" android:trackTint="#0A3050"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#0A2A40"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:text="🔕" android:textSize="13sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Silent Override" android:textColor="#A8D4F0" android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ring even when muted" android:textColor="#3A6080" android:textSize="10sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switchSilentOverride" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="#2DA86E" android:trackTint="#0A3050"/>
                </LinearLayout>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NAVIGATION" android:textColor="#1A4060" android:textSize="9sp"
                android:textStyle="bold" android:letterSpacing="0.15" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:text="🌙" android:textSize="13sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Dark Mode" android:textColor="#A8D4F0" android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Always on" android:textColor="#3A6080" android:textSize="10sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switchDarkMode" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:checked="true"
                        android:thumbTint="#2DA86E" android:trackTint="#0A3050"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#0A2A40"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:text="🔋" android:textSize="13sp" android:gravity="center" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Battery Saver" android:textColor="#A8D4F0" android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Reduce GPS updates" android:textColor="#3A6080" android:textSize="10sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switchBatterySaver" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="#2DA86E" android:trackTint="#0A3050"/>
                </LinearLayout>
            </LinearLayout>

            <Button android:id="@+id/btnPreviewAlarm"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="PREVIEW ALARM SOUND" android:textColor="#2DA86E"
                android:textStyle="bold" android:background="@drawable/btn_login_outline"
                android:layout_marginBottom="12dp"/>

            <Button android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="SAVE SETTINGS" android:textColor="#FFFFFF"
                android:textStyle="bold" android:textSize="15sp"
                android:background="@drawable/btn_primary"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>